# Database (from Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_USER_ID=your_user_id_from_userinfobot

# MyFitnessPal (optional for now, we'll add later)
MFP_USERNAME=
MFP_PASSWORD=

# Anthropic (for LLM messages + hey chat)
ANTHROPIC_API_KEY=your_key_from_console.anthropic.com

# Tavily (for web search — weather, transit, etc.)
TAVILY_API_KEY=your_key_from_tavily.com

# Server config
PORT=8000